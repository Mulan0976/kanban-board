{
  "name": "kanban-board",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n worker,client -c green,blue \"npm run dev:worker\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:worker": "wrangler dev",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply kanban-board-db",
    "db:migrate:local": "wrangler d1 migrations apply kanban-board-db --local"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "hono": "^4.4.0",
    "jose": "^5.6.0",
    "lucide-react": "^0.344.0",
    "p5": "^2.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.0",
    "three": "^0.183.2",
    "vanta": "^0.5.24",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "wrangler": "^3.99.0"
  }
}
