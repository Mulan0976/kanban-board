    "react-router-dom": "^6.22.0",
    "sql.js": "^1.10.0",
    "three": "^0.183.2",
    "uuid": "^9.0.1",
    "vanta": "^0.5.24",
    "ws": "^8.16.0",
    "zustand": "^4.5.0"
